# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# YAML files
[*.{yml,yaml}]
indent_size = 2
indent_style = space

# JSON files
[*.json]
indent_size = 2
indent_style = space

# JavaScript/TypeScript files
[*.{js,ts,jsx,tsx}]
indent_size = 2
indent_style = space

# Python files
[*.py]
indent_size = 4
indent_style = space

# PowerShell files
[*.ps1]
indent_size = 4
indent_style = space

# Makefile
[Makefile]
indent_style = tab
